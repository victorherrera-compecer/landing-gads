            background: var(--navy);
        }

        #process .section-title {
            color: var(--white);
        }

        #process .section-label {
            color: var(--gold);
        }

        .steps {
            display: flex;
            flex-direction: column;
            gap: 0;
            margin-top: 48px;
            position: relative;
        }

        .steps::before {
            content: '';
            position: absolute;
            left: 32px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, var(--gold), rgba(245, 166, 35, 0.1));
        }

        .step {
            display: flex;
            align-items: flex-start;
            gap: 28px;
            padding: 24px 0;
            position: relative;
