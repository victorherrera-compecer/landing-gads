    <script>
        // ─── URL DEL APPS SCRIPT ───
        const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxcKhnS_j_ExxaLqr36HAG0TR2REkTwRGqrrcypgCBntJhj1pAeIgzULFJhtLYU4Q_hvQ/exec';

       

        // ─── 2. FADE UP OBSERVER ───
        const fadeObserver = new IntersectionObserver((entries) => {
            entries.forEach(el => { if (el.isIntersecting) { el.target.style.opacity = '1'; el.target.style.transform = 'translateY(0)'; } });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
        document.querySelectorAll('.pain-card, .why-card, .benefit-card, .testi-card, .step').forEach(el => {
            el.style.opacity = '0'; el.style.transform = 'translateY(20px)';
            el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            fadeObserver.observe(el);
        });

        // ─── 3. CARRUSELES ───
        function initCarousel(selector) {
            const containers = document.querySelectorAll(selector);
            containers.forEach(container => {
                const track = container.querySelector('.carousel-track');
                const slides = track.querySelectorAll('.carousel-slide');
                const prevBtn = container.querySelector('.carousel-prev, .prev');
                const nextBtn = container.querySelector('.carousel-next, .next');
                const dotsContainer = container.querySelector('.carousel-dots');
                let current = 0, autoPlayInterval;
                dotsContainer.innerHTML = '';
                slides.forEach((_, i) => {
                    const dot = document.createElement('button');
                    dot.classList.add('carousel-dot');
                    dot.setAttribute('aria-label', `Ir a slide ${i + 1}`);
                    if (i === 0) dot.classList.add('active');
                    dot.addEventListener('click', () => goTo(i));
                    dotsContainer.appendChild(dot);
                });
                const dots = dotsContainer.querySelectorAll('.carousel-dot');
                function goTo(index) {
                    current = (index + slides.length) % slides.length;
                    track.style.transform = `translateX(-${current * 100}%)`;
                    dots.forEach((d, i) => d.classList.toggle('active', i === current));
                    resetAutoPlay();
                }
                function next() { goTo(current + 1); }
                function prev() { goTo(current - 1); }
                prevBtn?.addEventListener('click', prev);
                nextBtn?.addEventListener('click', next);
                let startX = 0, startY = 0;
                track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; startY = e.touches[0].clientY; }, { passive: true });
                track.addEventListener('touchend', e => {
                    const diffX = startX - e.changedTouches[0].clientX;
                    const diffY = startY - e.changedTouches[0].clientY;
                    if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 40) { diffX > 0 ? next() : prev(); }
                }, { passive: true });
                function startAutoPlay() {
                    autoPlayInterval = setInterval(() => {
                        // Si hay un video reproduciéndose, no avanzar
                        const activeSlide = slides[current];
                        if (activeSlide && activeSlide.querySelector('iframe')) return;
                        next();
                    }, 6000);
                }
                function resetAutoPlay() { clearInterval(autoPlayInterval); startAutoPlay(); }
                startAutoPlay();
                container.addEventListener('mouseenter', () => clearInterval(autoPlayInterval));
                container.addEventListener('mouseleave', startAutoPlay);
                container.addEventListener('touchstart', () => clearInterval(autoPlayInterval), { passive: true });
                container.addEventListener('touchend', startAutoPlay, { passive: true });
            });
        }

        // ─── 4. YOUTUBE LAZY LOAD (FIX #1) ───
        // NO se carga la API de YouTube. Solo thumbnails estáticos.
        // Al hacer clic, se reemplaza el thumbnail por un iframe con autoplay.
        function loadYTPlayer(wrap) {
            const videoId = wrap.dataset.videoid;
            // Reemplazar contenido: eliminar img y botón, insertar iframe
            wrap.innerHTML = `
                <iframe
                    src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1"
                    allow="autoplay; encrypted-media"
                    allowfullscreen
                    style="position:absolute;inset:0;width:100%;height:100%;border:none;border-radius:var(--radius);"
                ></iframe>`;
            // Quitar el cursor pointer ya que el iframe toma el control
            wrap.style.cursor = 'default';
        }

        // ─── 5. FORM VALIDATION + ENVÍO ───
        const form = document.getElementById('iso-form-27001');
        const emailInput = document.getElementById('email-corporativo');
        const whatsappInput = document.getElementById('whatsapp-input');
        const btnSubmit = document.getElementById('btn-submit');
        const personalDomains = ['gmail.com','yahoo.com','hotmail.com','outlook.com','live.com','icloud.com','protonmail.com','mail.com','aol.com','zoho.com','yandex.com','gmx.com'];

        function showError(input, message) {
            const group = input.closest('.form-group');
            group.classList.add('has-error');
            const error = group.querySelector('.form-error');
            if (error) error.textContent = message;
        }
        function hideError(input) {
            input.closest('.form-group').classList.remove('has-error');
        }

        function validateEmail(value) {
            const domain = value.toLowerCase().split('@')[1];
            if (!value) return 'Este campo es obligatorio';
            if (!value.includes('@')) return 'Ingresa un correo válido';
            if (domain && personalDomains.includes(domain)) return 'Usa un correo corporativo de tu empresa';
            return null;
        }

        function validatePhone(value) {
            const digits = value.replace(/\D/g, '');
            if (!value) return 'Este campo es obligatorio';
            if (digits.length < 8) return 'El número debe tener al menos 8 dígitos';
            return null;
        }

        function validateRequired(value) {
            if (!value || value.trim() === '') return 'Este campo es obligatorio';
            return null;
        }

        function checkFormValidity() {
            const fields = form.querySelectorAll('input, select');
            let allValid = true;
            fields.forEach(field => {
                if (field.name === 'email') {
                    if (validateEmail(field.value)) allValid = false;
                } else if (field.name === 'whatsapp') {
                    if (validatePhone(field.value)) allValid = false;
                } else {
                    if (validateRequired(field.value)) allValid = false;
                }
            });
            const recaptchaDone = grecaptcha.getResponse().length > 0;
            btnSubmit.disabled = !(allValid && recaptchaDone);
        }

        emailInput.addEventListener('input', function() {
            const error = validateEmail(this.value);
            if (error) showError(this, error); else hideError(this);
            checkFormValidity();
        });

        whatsappInput.addEventListener('input', function() {
            this.value = this.value.replace(/[^\d\+\s\-]/g, '');
            const error = validatePhone(this.value);
            if (error) showError(this, error); else hideError(this);
            checkFormValidity();
        });

        form.querySelectorAll('input:not(#email-corporativo):not(#whatsapp-input), select').forEach(field => {
            field.addEventListener('input', () => {
                const error = validateRequired(field.value);
                if (error) showError(field, error); else hideError(field);
                checkFormValidity();
            });
            field.addEventListener('change', () => {
                const error = validateRequired(field.value);
                if (error) showError(field, error); else hideError(field);
                checkFormValidity();
            });
        });

        window.onRecaptchaSuccess = function() { checkFormValidity(); };
        window.onRecaptchaExpired = function() { btnSubmit.disabled = true; };

        window.handleSubmit = async function(e) {
            e.preventDefault();
            const recaptchaResponse = grecaptcha.getResponse();
            const recaptchaError = document.getElementById('recaptcha-error');
            if (recaptchaResponse.length === 0) { recaptchaError.style.display = 'block'; return; }
            else { recaptchaError.style.display = 'none'; }

            const btn = document.getElementById('btn-submit');
            btn.textContent = '⏳ Enviando...';
            btn.disabled = true;

            const formData = new FormData(form);
            const payload = {
                tipo:      '27001',
                nombre:    formData.get('nombre'),
                empresa:   formData.get('empresa'),
                email:     formData.get('email'),
                whatsapp:  formData.get('whatsapp'),
                web:       formData.get('web'),
                cargo:     formData.get('cargo'),
                factor:    formData.get('factor'),
                mensaje:   '',
                recaptcha: recaptchaResponse
            };

            try {
                const response = await fetch(APPS_SCRIPT_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'text/plain' },
                    body: JSON.stringify(payload)
                });
                const result = await response.json();
                if (!result.success) throw new Error(result.message || 'Error desconocido');

                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({ event: 'form_submit_success', form_tipo: payload.tipo, form_empresa: payload.empresa });

                btn.textContent = '✅ ¡Enviado! Te contactaremos pronto';
                btn.style.background = '#22c55e';
                setTimeout(() => {
                    form.reset();
                    document.querySelectorAll('.form-group').forEach(g => g.classList.remove('has-error'));
                    btn.textContent = '👉 Enviar y recibir diagnóstico';
                    btn.style.background = '';
                    btn.disabled = true;
                    grecaptcha.reset();
                }, 5000);

            } catch (err) {
                console.error('Error al enviar:', err);
                btn.textContent = '❌ Error al enviar. Intenta de nuevo';
                btn.style.background = '#dc2626';
                setTimeout(() => {
