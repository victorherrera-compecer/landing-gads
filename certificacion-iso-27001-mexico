// Cargar reCAPTCHA solo cuando el usuario toca el formulario
const formSection = document.getElementById('hero-form');
let recaptchaLoaded = false;

function loadRecaptchaOnDemand() {
    if (!recaptchaLoaded) {
        const script = document.createElement('script');
        script.src = 'https://www.google.com/recaptcha/api.js';
        script.async = true;
        script.defer = true;
        document.head.appendChild(script);
        recaptchaLoaded = true;
        // Quitar los listeners para no cargarlo dos veces
        formSection.removeEventListener('click', loadRecaptchaOnDemand);
        formSection.removeEventListener('mouseover', loadRecaptchaOnDemand);
    }
}

if (formSection) {
    // Se carga si hacen click o pasan el mouse por encima del form
    formSection.addEventListener('click', loadRecaptchaOnDemand);
    formSection.addEventListener('mouseover', loadRecaptchaOnDemand, { once: true });
}
