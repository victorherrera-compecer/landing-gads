// ─── GTM DIFERIDO: carga tras primera interacción del usuario ───
(function() {
    var gtmLoaded = false;

    function loadGTM() {
        if (gtmLoaded) return;
        gtmLoaded = true;

        (function(w,d,s,l,i){
            w[l]=w[l]||[];
            w[l].push({'gtm.start': new Date().getTime(), event:'gtm.js'});
            var f=d.getElementsByTagName(s)[0],
                j=d.createElement(s),
                dl=l!='dataLayer'?'&l='+l:'';
            j.async=true;
            j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
            f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-XXXXXXX');

        // Limpiar listeners
        ['click','scroll','keydown','touchstart','mousemove'].forEach(function(e) {
            document.removeEventListener(e, loadGTM);
        });
    }

    // Disparar en primera interacción real del usuario
    ['click','scroll','keydown','touchstart','mousemove'].forEach(function(e) {
        document.addEventListener(e, loadGTM, { once: true, passive: true });
    });

    // Fallback: cargar a los 5 segundos aunque no haya interacción
    setTimeout(loadGTM, 5000);
})();
