    <style>
        :root {
            --navy: #1E2889;
            --navy-mid: #112347;
            --navy-light: #1A3260;
            --gold: #00C853;
            --gold-dark: #D4891A;
            --gold-light: #FFD580;
            --white: #FFFFFF;
            --off-white: #F7F9FC;
            --gray-light: #E8EDF5;
            --gray-mid: #8A9BBD;
            --text-dark: #0B1D3A;
            --text-body: #2E3F5C;
            --radius: 12px;
            --shadow: 0 8px 32px rgba(11, 29, 58, 0.13);
            --shadow-gold: 0 4px 24px rgba(245, 166, 35, 0.25);
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }

        html {
            scroll-behavior: smooth;
            -webkit-text-size-adjust: 100%;
            overflow-x: hidden;
            overscroll-behavior: none;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            color: var(--text-dark);
            background: var(--white);
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        h1,
        h2,
        h3,
        h4 {
            font-family: 'Sora', sans-serif;
        }

        img,
        video,
        svg,
        iframe {
            max-width: 100%;
            height: auto;
            display: block;
        }

        button,
        a,
        input,
        select,
        .btn-primary {
            touch-action: manipulation;
        }

