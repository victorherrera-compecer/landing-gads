        #main-header {
            position: relative;
            width: 100%;
            background: var(--navy);
            display: none; /* Ocultamos el header antiguo */
        }

        .sticky-hero-cta {
            position: fixed;
            top: 16px;
            left: 50%;
            -webkit-transform: translate(-50%, -150px);
            transform: translate(-50%, -150px);
            z-index: 999;
            opacity: 0;
            pointer-events: none;
            transition: -webkit-transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
            transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
            will-change: transform, opacity;
        }

        .sticky-hero-cta.visible {
            -webkit-transform: translate(-50%, 0);
            transform: translate(-50%, 0);
            opacity: 1;
            pointer-events: auto;
        }

        .sticky-hero-cta .btn-primary {
            padding: 12px 28px;
            font-size: 0.9rem;
            border-radius: 50px;
            box-shadow: 0 8px 32px rgba(245, 166, 35, 0.45);
            -webkit-transform: translateZ(0);
            transform: translateZ(0);
        }

        #hero {
            min-height: 100vh;
            min-height: -webkit-fill-available;
            background: var(--navy);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            padding: 60px 3% 80px;
            width: 100%;
            gap: 60px;
        }

        #hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 60% 60% at 80% 20%, rgba(245, 166, 35, 0.12) 0%, transparent 70%), radial-gradient(ellipse 50% 50% at 10% 80%, rgba(26, 50, 96, 0.8) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero-grid-lines {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(245, 166, 35, 0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(245, 166, 35, 0.04) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 700px;
            text-align: left;
            flex: 1.2;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(0, 200, 83, 0.15);
            border: 1px solid rgba(0, 200, 83, 0.4);
            color: var(--gold);
            font-family: 'Sora', sans-serif;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            padding: 6px 16px;
            border-radius: 100px;
            margin-bottom: 28px;
            text-transform: uppercase;
            position: relative;
            overflow: hidden;
            -webkit-transform: translateZ(0);
            transform: translateZ(0);
        }

        .hero-badge::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 75%;
            height: 100%;
            background: linear-gradient(to right, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.6) 50%, rgba(255, 255, 255, 0) 100%);
            -webkit-transform: skewX(-25deg);
            transform: skewX(-25deg);
            -webkit-animation: shine 10s infinite;
            animation: shine 10s infinite;
            -webkit-animation-timing-function: ease-in-out;
            animation-timing-function: ease-in-out;
            pointer-events: none;
        }

        @-webkit-keyframes shine {
            0% { left: -100%; }
            70% { left: 150%; }
            100% { left: 150%; }
        }

        @keyframes shine {
            0% { left: -100%; }
            70% { left: 150%; }
            100% { left: 150%; }
        }

        .hero-content h1 {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 800;
            color: var(--white);
            line-height: 1.2;
            letter-spacing: -0.03em;
